PRACTICEHELPER_WEB_HOST=0.0.0.0
PRACTICEHELPER_WEB_PORT=5173
PRACTICEHELPER_WEB_API_PROXY_TARGET=http://127.0.0.1:8090

PRACTICEHELPER_SERVER_PORT=8090
PRACTICEHELPER_SERVER_DB_PATH=../data/practicehelper.db
PRACTICEHELPER_SERVER_SIDECAR_URL=http://127.0.0.1:8000
PRACTICEHELPER_SERVER_SIDECAR_TIMEOUT_SECONDS=90
PRACTICEHELPER_INTERNAL_TOKEN=dev-internal-token
PRACTICEHELPER_SERVER_LOG_PATH=../data/logs/server.log
# 当前 vector store provider 只实现 qdrant；本地 Docker 和 Qdrant Cloud 都走这一组配置。
PRACTICEHELPER_SERVER_VECTOR_STORE_PROVIDER=qdrant
PRACTICEHELPER_SERVER_VECTOR_STORE_URL=http://127.0.0.1:6333
PRACTICEHELPER_SERVER_VECTOR_STORE_API_KEY=
PRACTICEHELPER_SERVER_VECTOR_STORE_COLLECTION=practicehelper_memory
PRACTICEHELPER_SERVER_VECTOR_STORE_TIMEOUT_SECONDS=8
# 开启 repo/memory 向量检索时，把下面三个开关改成 true。
PRACTICEHELPER_SERVER_VECTOR_WRITE_ENABLED=false
PRACTICEHELPER_SERVER_VECTOR_READ_ENABLED=false
PRACTICEHELPER_SERVER_VECTOR_RERANK_ENABLED=false
PRACTICEHELPER_SERVER_MEMORY_HOT_INDEX_TIMEOUT_SECONDS=2
PRACTICEHELPER_SERVER_MEMORY_EMBEDDING_CLAIM_TTL_SECONDS=20
PRACTICEHELPER_SERVER_MEMORY_EMBEDDING_POLL_SECONDS=4

# 本地 OpenAI-compatible 服务通常不要求鉴权；这三组 API_KEY 留空也能工作。
PRACTICEHELPER_SIDECAR_MODEL=
PRACTICEHELPER_SIDECAR_OPENAI_BASE_URL=
PRACTICEHELPER_SIDECAR_OPENAI_API_KEY=
PRACTICEHELPER_SIDECAR_LLM_TIMEOUT_SECONDS=45
# repo chunk / memory 向量召回和 rerank 依赖下面这组配置。
PRACTICEHELPER_SIDECAR_EMBEDDING_MODEL=
PRACTICEHELPER_SIDECAR_EMBEDDING_BASE_URL=
PRACTICEHELPER_SIDECAR_EMBEDDING_API_KEY=
PRACTICEHELPER_SIDECAR_EMBEDDING_TIMEOUT_SECONDS=10
PRACTICEHELPER_SIDECAR_RERANK_MODEL=
PRACTICEHELPER_SIDECAR_RERANK_BASE_URL=
PRACTICEHELPER_SIDECAR_RERANK_API_KEY=
PRACTICEHELPER_SIDECAR_RERANK_TIMEOUT_SECONDS=10
PRACTICEHELPER_SIDECAR_SERVER_BASE_URL=http://127.0.0.1:8090
PRACTICEHELPER_SIDECAR_BACKEND_TIMEOUT_SECONDS=10
PRACTICEHELPER_SIDECAR_GITHUB_TOKEN=
PRACTICEHELPER_SIDECAR_LOG_PATH=../data/logs/sidecar.log
